### Register
POST {{api_HostAddress}}/auth/register
Accept: application/json
Content-Type: application/json

{
    "name": "chafiaayap",
    "password": "123456789",
    "email": "chafiaayao@gmail.com"
}

### Login
POST {{api_HostAddress}}/auth/login
Accept: application/json
Content-Type: application/json

{
    "email": "chafiaay@gmail.com",
    "password": "12345678"
}

### Refresh Token
POST {{api_HostAddress}}/auth/refresh
Accept: application/json
Content-Type: application/json

{
    "refreshToken": "{{refreshToken}}"
}

### Logout
POST {{api_HostAddress}}/auth/logout
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

### Create Product
POST {{api_HostAddress}}/products
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "name": "Product 2",
    "price": 100,
    "description": "Test product 2 description"
}

### Get All Products
GET {{api_HostAddress}}/products

### Get Single Product
GET {{api_HostAddress}}/products/UIleEGsFCNQHHZYNi5M0

### Update Product
PUT {{api_HostAddress}}/products/UIleEGsFCNQHHZYNi5M0
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "name": "Updated Product",
    "price": 150
}

### Delete Product
DELETE {{api_HostAddress}}/products/uIqHLC7A6IxWTg61fVoK
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

### Create Order
POST {{api_HostAddress}}/orders
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "items": [
        {
            "productId": "UIleEGsFCNQHHZYNi5M0",
            "quantity": 2,
            "price": 100
        }
    ],
    "total": 200
}

### Get User Orders
GET {{api_HostAddress}}/orders
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

### Get All Orders
GET {{api_HostAddress}}/orders/all
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

### Get Order Details
GET {{api_HostAddress}}/orders/hQUx1wCPyHYpmCtnmNoV/items
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

### Update Order Status
PATCH {{api_HostAddress}}/orders/hQUx1wCPyHYpmCtnmNoV/status
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "status": "completed"
}