@api_HostAddress = http://localhost:5000
@token = YOUR_ID_TOKEN_HERE
@refreshToken = YOUR_REFRESH_TOKEN_HERE

# ===== AUTH =====

### Register
POST {{api_HostAddress}}/auth/register
Accept: application/json
Content-Type: application/json

{
    "name": "Test User",
    "password": "123456789",
    "email": "newuser@test.com"
}

### Login
POST {{api_HostAddress}}/auth/login
Accept: application/json
Content-Type: application/json

{
    "email": "user@test.com",
    "password": "Password123!"
}

### Refresh Token
POST {{api_HostAddress}}/auth/refresh
Accept: application/json
Content-Type: application/json

{
    "refreshToken": "{{refreshToken}}"
}

### Logout
POST {{api_HostAddress}}/auth/logout
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

# ===== PRODUCTS (Public for GET) =====

### Get All Products
GET {{api_HostAddress}}/products

### Get Single Product
GET {{api_HostAddress}}/products/PRODUCT_ID

# ===== PRODUCTS (Admin Only) =====

### Create Product (Admin)
POST {{api_HostAddress}}/products
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "name": "Product 1",
    "price": 100,
    "description": "Test product"
}

### Update Product (Admin)
PUT {{api_HostAddress}}/products/PRODUCT_ID
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "name": "Updated Product",
    "price": 150
}

### Delete Product (Admin)
DELETE {{api_HostAddress}}/products/PRODUCT_ID
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

# ===== ORDERS (Client - Own Orders Only) =====

### Create Order (Authenticated)
POST {{api_HostAddress}}/orders
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "items": [
        {
            "productId": "PRODUCT_ID",
            "quantity": 2,
            "price": 100
        }
    ],
    "total": 200
}

### Get My Orders (Client)
GET {{api_HostAddress}}/orders
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

### Get My Order Details
GET {{api_HostAddress}}/orders/ORDER_ID/items
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

# ===== ORDERS (Admin Only) =====

### Get All Orders (Admin)
GET {{api_HostAddress}}/orders/all
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

### Update Order Status (Admin)
PATCH {{api_HostAddress}}/orders/ORDER_ID/status
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "status": "completed"
}

# ===== ADMIN (Admin Only) =====

### Get All Users (Admin)
GET {{api_HostAddress}}/admin/users
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

### Set User Role (Admin)
POST {{api_HostAddress}}/admin/set-role
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "uid": "USER_UID",
    "role": "admin"
}